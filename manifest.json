{
  "manifest_version": 2,
  "name": "Startbildschirm Designer",
  "version": "1.0.0",
  "description": "Gestalte deinen Firefox-Startbildschirm als eigene New-Tab-Seite.",
  "permissions": ["storage", "search", "unlimitedStorage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "chrome_settings_overrides": {
    "homepage": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "startbildschirm-designer@local",
      "strict_min_version": "109.0"
    }
  }
}
